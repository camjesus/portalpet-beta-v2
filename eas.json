{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "debug": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true
      },
      "developmentClient": false
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "ENV": "prod",
        "GOOGLE_ANDROID_ID": "@GOOGLE_ANDROID_ID",
        "GOOGLE_IOS_ID": "@GOOGLE_IOS_ID",
        "GOOGLE_WEB_ID": "@GOOGLE_WEB_ID",
        "API_KEY_LOCATIONIQ": "@API_KEY_LOCATIONIQ"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "ios": {},
      "env": {
        "ENV": "prod",
        "GOOGLE_ANDROID_ID": "@GOOGLE_ANDROID_ID",
        "GOOGLE_IOS_ID": "@GOOGLE_IOS_ID",
        "GOOGLE_WEB_ID": "@GOOGLE_WEB_ID"
      }
    }
  }
}