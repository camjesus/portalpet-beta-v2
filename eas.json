{
  "build": {
    "debug": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "developmentClient": false
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "ENV": "production",
        "GOOGLE_ANDROID_ID": "@GOOGLE_ANDROID_ID",
        "GOOGLE_WEB_ID": "@GOOGLE_WEB_ID"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ENV": "production"
      }
    }
  }
}
